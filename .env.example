# Frontend Configuration
# The URL where your backend API is hosted. 
# For local development, use: http://localhost:8000
REACT_APP_BACKEND_URL=http://localhost:8000

# Backend Configuration (Optional)
# Netscape-formatted cookies to bypass platform rate-limits or access private content.
# Paste the entire content of your cookies.txt file here if needed.
YDL_COOKIES=

# Enable debug mode for more verbose backend logging (true/false)
DEBUG=false
